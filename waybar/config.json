{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/network", "bluetooth", "pulseaudio", "backlight", "cpu", "memory", "battery", "custom/notifications"],

  "custom/launcher": {
    "format": "ΎΝΥ",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },

  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ΎΕι",
      "2": "≤░Ι╣",
      "3": "≤░βψ",
      "4": "≤░ΟΕ",
      "5": "≤░φ╣",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },

  "clock": {
    "format": "{:%a %b %d  %I:%M %p}",
    "tooltip-format": "<big>{:%Y-%m-%d}</big>\n<tt>{calendar}</tt>"
  },

  "custom/network": {
    "exec": "bash -lc 'echo \"≤░ΙΑ\"'",
    "interval": 30,
    "tooltip": false,
    "on-click": "nm-connection-editor",
    "on-click-right": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "ΎΛΦ",
    "format-disabled": "≤░Γ▓",
    "format-connected": "ΎΛΦ {num_connections}",
    "tooltip-format": "{controller_alias}"
  },

  "pulseaudio": {
    "format": "{icon}  {volume:>3}%",
    "format-muted": "≤░ζθ  muted",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },

  "backlight": {
    "format": "≤░Δθ  {percent}%"
  },

  "cpu": {
    "format": "ΎΤ╝  {usage:>3}%"
  },

  "memory": {
    "format": "Ό┐Ζ  {percentage:>3}%"
  },

  "battery": {
    "format": "{icon}  {capacity}%",
    "format-charging": "≤░ΓΕ  {capacity}%",
    "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
  },

  "custom/notifications": {
    "format": "ΎΔ│",
    "tooltip": false,
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d"
  }
}
