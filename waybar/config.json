{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "custom/clock"
  ],
  "modules-right": [
    "custom/net",
    "bluetooth",
    "custom/cpu",
    "custom/memory",
    "pulseaudio",
    "backlight",
    "battery",
    "custom/notifications"
  ],
  "custom/launcher": {
    "format": "´îô",
    "tooltip": false,
    "on-click": "anyrun",
    "on-click-right": "wlogout --protocol layer-shell"
  },
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{windows}",
    "window-rewrite-default": "´äæ",
    "window-rewrite": {
      "class<ghostty>": "´äá",
      "class<com.mitchellh.ghostty>": "´äá",
      "class<chromium>": "´ë¿",
      "class<chromium-browser>": "´ë¿",
      "class<Chromium-browser>": "´ë¿",
      "class<firefox>": "´ë®",
      "class<nautilus>": "¾░ëï",
      "class<org.gnome.Nautilus>": "¾░ëï",
      "class<discord>": "¾░Ö»",
      "class<neovim>": "¯İ½",
      "class<nvim>": "¯İ½",
      "class<code>": "¯£î",
      "class<Code>": "¯£î",
      "class<Code - OSS>": "¯£î",
      "class<btop>": "´éÇ",
      "class<pavucontrol>": "¾░àÂ",
      "class<nm-connection-editor>": "¾░ñ¿"
    }
  },
  "custom/net": {
    "exec": "waybar-net",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e sudo iftop",
    "on-click-right": "nm-connection-editor"
  },
  "bluetooth": {
    "format": "¾░é▓",
    "format-disabled": "¾░è▓",
    "format-connected": "¾░é» {num_connections}",
    "tooltip-format": "{controller_alias}"
  },
  "custom/cpu": {
    "exec": "waybar-cpu",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e btop -p 0"
  },
  "custom/memory": {
    "exec": "waybar-mem",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e btop -p 1"
  },
  "pulseaudio": {
    "format": "{icon}  {volume:>3}%",
    "format-muted": "¾░©ê  muted",
    "format-icons": {
      "default": [
        "´ÇĞ",
        "´Çğ",
        "´Ç¿"
      ]
    },
    "on-click": "pavucontrol"
  },
  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": [
      "´Çê",
      "´Çà"
    ]
  },
  "battery": {
    "format": "{icon}  {capacity}%",
    "format-charging": "´âğ  {capacity}%",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ],
    "states": {
      "warning": 30,
      "critical": 15
    }
  },
  "custom/notifications": {
    "exec": "waybar-notify",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "tooltip": false,
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d"
  },
  "custom/clock": {
    "exec": "waybar-clock",
    "return-type": "json",
    "interval": 30,
    "format": "{}",
    "tooltip": true
  }
}