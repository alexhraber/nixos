{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "custom/clock"
  ],
  "modules-right": [
    "custom/net",
    "bluetooth",
    "custom/cpu",
    "custom/memory",
    "pulseaudio",
    "backlight",
    "battery",
    "custom/notifications"
  ],
  "custom/launcher": {
    "format": "ΎΝΥ",
    "tooltip": false,
    "on-click": "anyrun",
    "on-click-right": "wlogout --protocol layer-shell"
  },
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{windows}",
    "window-rewrite-default": "ΎΕΣ",
    "window-rewrite": {
      "class<ghostty>": "ΎΕι",
      "class<com.mitchellh.ghostty>": "ΎΕι",
      "class<chromium>": "ΎΚρ",
      "class<chromium-browser>": "ΎΚρ",
      "class<Chromium-browser>": "ΎΚρ",
      "class<firefox>": "ΎΚσ",
      "class<nautilus>": "≤░ΚΜ",
      "class<org.gnome.Nautilus>": "≤░ΚΜ",
      "class<discord>": "≤░βψ",
      "class<neovim>": "Όατ",
      "class<nvim>": "Όατ",
      "class<code>": "ΌεΝ",
      "class<Code>": "ΌεΝ",
      "class<Code - OSS>": "ΌεΝ",
      "class<btop>": "ΎΓΑ",
      "class<pavucontrol>": "≤░Ζ╢",
      "class<nm-connection-editor>": "≤░νρ"
    }
  },
  "custom/net": {
    "exec": "waybar-net",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e sudo iftop",
    "on-click-right": "nm-connection-editor"
  },
  "bluetooth": {
    "format": "ΎΛΦ",
    "format-disabled": "≤░Λ▓",
    "format-connected": "ΎΛΦ {num_connections}",
    "tooltip-format": "{controller_alias}"
  },
  "custom/cpu": {
    "exec": "waybar-cpu",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e btop -p 0"
  },
  "custom/memory": {
    "exec": "waybar-mem",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e btop -p 1"
  },
  "pulseaudio": {
    "format": "{icon}  {volume:>3}%",
    "format-muted": "≤░╕Ι  muted",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": [
      "ΎΑΙ",
      "ΎΑΖ"
    ]
  },
  "battery": {
    "format": "{icon}  {capacity}%",
    "format-charging": "ΎΔπ  {capacity}%",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ],
    "states": {
      "warning": 30,
      "critical": 15
    }
  },
  "custom/notifications": {
    "exec": "waybar-notify",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "tooltip": false,
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d"
  },
  "custom/clock": {
    "exec": "waybar-clock",
    "return-type": "json",
    "interval": 30,
    "format": "{}",
    "tooltip": true
  }
}