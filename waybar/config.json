{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/net", "bluetooth", "custom/cpu", "custom/memory", "pulseaudio", "custom/notifications"],

  "custom/launcher": {
    "format": "",
    "tooltip": false,
    "on-click": "rofi -show combi"
  },

  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "",
      "2": "󰈹",
      "3": "󰙯",
      "4": "󰎄",
      "5": "󰭹",
      "active": "",
      "default": ""
    }
  },

  "clock": {
    "format": "{:%a %b %d  %I:%M %p}",
    "tooltip-format": "<big>{:%Y-%m-%d}</big>\n<tt>{calendar}</tt>"
  },

  "custom/net": {
    "exec": "waybar-net",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "tooltip": true,
    "on-click": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "",
    "format-disabled": "󰂲",
    "format-connected": " {num_connections}",
    "tooltip-format": "{controller_alias}"
  },

  "custom/cpu": {
    "exec": "waybar-cpu",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e btop"
  },

  "custom/memory": {
    "exec": "waybar-mem",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "tooltip": true,
    "on-click": "ghostty -e btop --preset memory"
  },

  "pulseaudio": {
    "format": "{icon}  {volume:>3}%",
    "format-muted": "󰝟  muted",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol"
  },

  "custom/notifications": {
    "format": "",
    "tooltip": false,
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d"
  }
}
