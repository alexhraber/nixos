{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/network", "bluetooth", "cpu", "memory", "pulseaudio", "custom/notifications"],

  "custom/launcher": {
    "format": "",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },

  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "",
      "2": "󰈹",
      "3": "󰙯",
      "4": "󰎄",
      "5": "󰭹",
      "active": "",
      "default": ""
    }
  },

  "clock": {
    "format": "{:%a %b %d  %I:%M %p}",
    "tooltip-format": "<big>{:%Y-%m-%d}</big>\n<tt>{calendar}</tt>"
  },

  "custom/network": {
    "exec": "bash -lc 'echo \"󰈀\"'",
    "interval": 30,
    "tooltip": false,
    "on-click": "nm-connection-editor",
    "on-click-right": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "",
    "format-disabled": "󰂲",
    "format-connected": " {num_connections}",
    "tooltip-format": "{controller_alias}"
  },

  "pulseaudio": {
    "format": "{icon}  {volume:>3}%",
    "format-muted": "󰝟  muted",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol"
  },

  "cpu": {
    "format": "  {usage:>3}%"
  },

  "memory": {
    "format": "  {percentage:>3}%"
  },

  "custom/notifications": {
    "format": "",
    "tooltip": false,
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d"
  }
}
